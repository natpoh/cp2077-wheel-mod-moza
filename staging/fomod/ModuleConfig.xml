<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">

  <moduleName>Logitech G-series Wheel Mod</moduleName>

  <!-- No top-level moduleDependencies. Vortex already enforces game
       association before the FOMOD runs, and `state="Active"` checks
       mod-tracked files, not base-game files. Real prerequisites
       (RED4ext, ArchiveXL, Mod Settings, Logitech G HUB) are documented
       on the Nexus mod page using Nexus's native dependency / required-
       mods declarations rather than nagged through the FOMOD installer
       (FOMOD steps are for install-time customization, not info dumps). -->

  <!-- The only customization the user makes during install is the
       startup handshake on/off. Everything else is fixed payload. -->

  <requiredInstallFiles>
    <file source="build\gwheel.dll"
          destination="red4ext\plugins\gwheel\gwheel.dll"/>
    <file source="mod_settings\mod_settings.dll"
          destination="red4ext\plugins\mod_settings\mod_settings.dll"/>
    <file source="gwheel_reds\gwheel_natives.reds"
          destination="r6\scripts\gwheel\gwheel_natives.reds"/>
    <file source="gwheel_reds\gwheel_settings.reds"
          destination="r6\scripts\gwheel\gwheel_settings.reds"/>
    <file source="gwheel_reds\gwheel_mount.reds"
          destination="r6\scripts\gwheel\gwheel_mount.reds"/>
    <file source="gwheel_reds\gwheel_events.reds"
          destination="r6\scripts\gwheel\gwheel_events.reds"/>
    <file source="gwheel_reds\gwheel_surface.reds"
          destination="r6\scripts\gwheel\gwheel_surface.reds"/>
    <file source="gwheel_reds\gwheel_vehicle_signals.reds"
          destination="r6\scripts\gwheel\gwheel_vehicle_signals.reds"/>
  </requiredInstallFiles>

  <installSteps order="Explicit">

    <installStep name="Startup handshake">
      <optionalFileGroups order="Explicit">

        <group name="Pon pon shi handshake" type="SelectExactlyOne">
          <plugins order="Explicit">

            <plugin name="Pon pon shi greeting (on)">
              <description>On game start, briefly pulse the wheel's LEDs and force-feedback motors and run a centering spring to return the wheel to 0 degrees. Toggle anytime in the in-game Mod Settings menu.</description>
              <files>
                <file source="fomod_configs\config_handshake_on.json"
                      destination="red4ext\plugins\gwheel\config.json"/>
              </files>
              <typeDescriptor>
                <type name="Recommended"/>
              </typeDescriptor>
            </plugin>

            <plugin name="Pon pon shi greeting (off)">
              <description>Skip the startup pulses. The wheel stays silent on game start. Toggle anytime in the in-game Mod Settings menu.</description>
              <files>
                <file source="fomod_configs\config_handshake_off.json"
                      destination="red4ext\plugins\gwheel\config.json"/>
              </files>
              <typeDescriptor>
                <type name="Optional"/>
              </typeDescriptor>
            </plugin>

          </plugins>
        </group>

      </optionalFileGroups>
    </installStep>

  </installSteps>

</config>
